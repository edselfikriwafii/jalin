# ============================================================
# TEMPLATE ENVIRONMENT VARIABLES — JALIN
# Salin file ini menjadi .env dan isi nilainya.
# JANGAN commit file .env ke GitHub!
# ============================================================

# Database PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/jalin?schema=public"

# NextAuth.js v5
# AUTH_SECRET: generate dengan perintah: npx auth secret
AUTH_SECRET="isi-dengan-random-string-panjang-minimal-32-karakter"
AUTH_URL="http://localhost:3000"

# Resend — untuk kirim email verifikasi
# Daftar gratis di resend.com, ambil API key dari dashboard
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Jalin <noreply@yourdomain.com>"

# Anthropic Claude API — untuk penilaian IELTS
# Ambil dari: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google Gemini API — fallback jika Claude gagal
# Ambil dari: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
